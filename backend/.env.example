# Serveur
PORT=3000

# Base de données
MONGO_URI=mongodb://localhost:27017/hotel_management

# Authentification
JWT_SECRET=change_me_with_a_long_random_string

# Paiement Stripe
STRIPE_SECRET_KEY=sk_test_xxx
# Secret du webhook (Stripe CLI / dashboard). Vide = signature non vérifiée (dev only).
STRIPE_WEBHOOK_SECRET=

# Frontend (CORS + liens dans les emails)
FRONTEND_URL=http://localhost:8080

# Service email (SMTP). Si SMTP_HOST est vide, les emails sont loggés (mode console).
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=no-reply@hotel.com

# Compte admin créé par le script de seed
ADMIN_EMAIL=admin@hotel.com
ADMIN_PASSWORD=admin123
